# ── LLM PROVIDER ─────────────────────────────────────────────────────────────
# "nim"   — NVIDIA NIM, cloud-hosted, requires an API key (default)
# "local" — any OpenAI-compatible local server: Ollama, LM Studio, llama.cpp, vLLM
LLM_PROVIDER=nim

# ── NVIDIA NIM (only used when LLM_PROVIDER=nim) ────────────────────────────
# Get your API key from https://build.nvidia.com
NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Chat model — pick one:
# meta/llama-3.1-70b-instruct   (recommended)
# meta/llama-3.1-8b-instruct    (faster, cheaper)
# mistralai/mistral-large-2-instruct
NIM_CHAT_MODEL=meta/llama-3.1-70b-instruct

# Embedding model — pick one:
# nvidia/nv-embedqa-e5-v5        (recommended, 1024-dim)
# nvidia/llama-3.2-nv-embedqa-1b-v2  (faster)
NIM_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
NIM_EMBED_DIM=1024

# ── LOCAL LLM (only used when LLM_PROVIDER=local) ───────────────────────────
# Quickstart with Ollama:
#   1. Install: https://ollama.com
#   2. ollama pull llama3.1
#   3. ollama pull nomic-embed-text
#   4. ollama serve   (usually already running as a service)
#   5. Set LLM_PROVIDER=local below
#
# Ollama exposes an OpenAI-compatible API at /v1 — no code changes needed,
# just point LOCAL_LLM_BASE_URL at it. LM Studio works the same way (enable
# "Local Server" in its settings, default port 1234).
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_API_KEY=not-needed
LOCAL_CHAT_MODEL=llama3.1
LOCAL_EMBED_MODEL=nomic-embed-text
LOCAL_EMBED_DIM=768
LOCAL_LLM_TIMEOUT=120

# Set true only if your Ollama version doesn't expose /v1/embeddings
# (falls back to Ollama's native /api/embeddings endpoint, one request per text)
LOCAL_USE_OLLAMA_NATIVE_EMBEDDINGS=false

# NOTE: switching LLM_PROVIDER changes the embedding dimension, which means
# existing Qdrant vectors become incompatible with the new model. Re-run
# ingestion (or wipe the concepts/papers/domains collections) after switching.

# ── DATABASES ─────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=pandora_secret
POSTGRES_PASSWORD=pandora_secret

# ── APP ───────────────────────────────────────────────────────────────────────
ENV=development
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── AUTH ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Optional: Supabase Auth (for production JWT validation)
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# SUPABASE_URL=https://your-project.supabase.co

# ── INTEGRATION TESTS ─────────────────────────────────────────────────────────
# Set to 1 to run tests against real services (requires docker compose up)
INTEGRATION_TESTS=0
